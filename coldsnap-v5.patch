+/// Simple latency histogram for upload diagnostics.
+struct LatencyHistogram {
+    under_250ms: AtomicU64,
+    ms_250_500: AtomicU64,
+    ms_500_1s: AtomicU64,
+    s_1_2: AtomicU64,
+    s_2_5: AtomicU64,
+    over_5s: AtomicU64,
+    timeouts: AtomicU64,
+}
+
+impl LatencyHistogram {
+    fn new() -> Self {
+        Self {
+            under_250ms: AtomicU64::new(0),
+            ms_250_500: AtomicU64::new(0),
+            ms_500_1s: AtomicU64::new(0),
+            s_1_2: AtomicU64::new(0),
+            s_2_5: AtomicU64::new(0),
+            over_5s: AtomicU64::new(0),
+            timeouts: AtomicU64::new(0),
+        }
+    }
+
+    fn record_success(&self, elapsed: Duration) {
+        let ms = elapsed.as_millis();
+        if ms < 250 {
+            self.under_250ms.fetch_add(1, AtomicOrdering::Relaxed);
+        } else if ms < 500 {
+            self.ms_250_500.fetch_add(1, AtomicOrdering::Relaxed);
+        } else if ms < 1000 {
+            self.ms_500_1s.fetch_add(1, AtomicOrdering::Relaxed);
+        } else if ms < 2000 {
+            self.s_1_2.fetch_add(1, AtomicOrdering::Relaxed);
+        } else if ms < 5000 {
+            self.s_2_5.fetch_add(1, AtomicOrdering::Relaxed);
+        } else {
+            self.over_5s.fetch_add(1, AtomicOrdering::Relaxed);
+        }
+    }
+
+    fn record_timeout(&self) {
+        self.timeouts.fetch_add(1, AtomicOrdering::Relaxed);
+    }
+
+    fn report(&self) {
+        log::info!(
+            "Latency histogram: <250ms={} 250-500ms={} 500ms-1s={} 1-2s={} 2-5s={} >5s={} timeouts={}",
+            self.under_250ms.load(AtomicOrdering::Relaxed),
+            self.ms_250_500.load(AtomicOrdering::Relaxed),
+            self.ms_500_1s.load(AtomicOrdering::Relaxed),
+            self.s_1_2.load(AtomicOrdering::Relaxed),
+            self.s_2_5.load(AtomicOrdering::Relaxed),
+            self.over_5s.load(AtomicOrdering::Relaxed),
+            self.timeouts.load(AtomicOrdering::Relaxed),
+        );
+    }
+}
